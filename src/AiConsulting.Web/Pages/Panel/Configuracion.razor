@page "/panel/configuracion"
@layout PanelLayout
@attribute [Authorize]
@inject IPanelApiService PanelApi

<h4 class="mb-4">Configuración</h4>

<div class="row g-4">
    <!-- Webhooks -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">Notificaciones (Webhook)</h6>
                @if (_loadingConfig)
                {
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label small">Canal</label>
                        <select class="form-select form-select-sm" @bind="_configForm.Channel">
                            <option value="Slack">Slack</option>
                            <option value="Telegram">Telegram</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">URL del webhook</label>
                        <input class="form-control form-control-sm" type="url"
                               placeholder="https://hooks.slack.com/..." @bind="_configForm.WebhookUrl" />
                    </div>
                    <div class="mb-3 form-check">
                        <input class="form-check-input" type="checkbox" id="webhookActive"
                               @bind="_configForm.IsActive" />
                        <label class="form-check-label small" for="webhookActive">Activo</label>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="SaveConfig" disabled="@_savingConfig">
                        @if (_savingConfig) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                    @if (_configSaved) { <span class="text-success small ms-2">✓ Guardado</span> }
                }
            </div>
        </div>
    </div>

    <!-- Disponibilidad -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">Disponibilidad semanal</h6>
                @if (_loadingAvailability)
                {
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Día</th>
                                    <th>Inicio</th>
                                    <th>Fin</th>
                                    <th>Activo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var slot in _availabilityForms)
                                {
                                    <tr>
                                        <td class="small align-middle">@DayName(slot.DayOfWeek)</td>
                                        <td>
                                            <input class="form-control form-control-sm" type="time"
                                                   value="@slot.StartTime"
                                                   @onchange="e => slot.StartTime = e.Value?.ToString() ?? slot.StartTime"
                                                   style="width: 100px;" />
                                        </td>
                                        <td>
                                            <input class="form-control form-control-sm" type="time"
                                                   value="@slot.EndTime"
                                                   @onchange="e => slot.EndTime = e.Value?.ToString() ?? slot.EndTime"
                                                   style="width: 100px;" />
                                        </td>
                                        <td>
                                            <input class="form-check-input" type="checkbox"
                                                   @bind="slot.IsActive" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="SaveAvailability" disabled="@_savingAvailability">
                        @if (_savingAvailability) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar disponibilidad
                    </button>
                    @if (_availabilitySaved) { <span class="text-success small ms-2">✓ Guardado</span> }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private UpdateNotificationConfigModel _configForm = new() { Channel = "Slack" };
    private List<AvailabilityFormItem> _availabilityForms = [];
    private bool _loadingConfig = true;
    private bool _loadingAvailability = true;
    private bool _savingConfig;
    private bool _savingAvailability;
    private bool _configSaved;
    private bool _availabilitySaved;

    private class AvailabilityFormItem
    {
        public Guid Id { get; set; }
        public int DayOfWeek { get; set; }
        public string StartTime { get; set; } = "09:00";
        public string EndTime { get; set; } = "18:00";
        public bool IsActive { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadConfig(), LoadAvailability());
    }

    private async Task LoadConfig()
    {
        _loadingConfig = true;
        var config = await PanelApi.GetNotificationConfigAsync();
        if (config is not null)
        {
            _configForm = new UpdateNotificationConfigModel
            {
                Channel = config.Channel,
                WebhookUrl = config.WebhookUrl,
                IsActive = config.IsActive
            };
        }
        _loadingConfig = false;
    }

    private async Task LoadAvailability()
    {
        _loadingAvailability = true;
        var slots = await PanelApi.GetAvailabilityAsync();
        if (slots.Any())
        {
            _availabilityForms = slots.Select(s => new AvailabilityFormItem
            {
                Id = s.Id,
                DayOfWeek = s.DayOfWeek,
                StartTime = s.StartTime,
                EndTime = s.EndTime,
                IsActive = s.IsActive
            }).OrderBy(s => s.DayOfWeek).ToList();
        }
        else
        {
            // Default Mon-Sun
            _availabilityForms = Enumerable.Range(1, 7).Select(d => new AvailabilityFormItem
            {
                Id = Guid.Empty,
                DayOfWeek = d,
                StartTime = "09:00",
                EndTime = "18:00",
                IsActive = d <= 5
            }).ToList();
        }
        _loadingAvailability = false;
    }

    private async Task SaveConfig()
    {
        _savingConfig = true;
        await PanelApi.UpdateNotificationConfigAsync(_configForm);
        _savingConfig = false;
        _configSaved = true;
        StateHasChanged();
        await Task.Delay(2000);
        _configSaved = false;
    }

    private async Task SaveAvailability()
    {
        _savingAvailability = true;
        var dtos = _availabilityForms.Select(f => new UpdateAvailabilityModel
        {
            Id = f.Id,
            DayOfWeek = f.DayOfWeek,
            StartTime = f.StartTime,
            EndTime = f.EndTime,
            IsActive = f.IsActive
        }).ToList();
        await PanelApi.UpdateAvailabilityAsync(dtos);
        _savingAvailability = false;
        _availabilitySaved = true;
        StateHasChanged();
        await Task.Delay(2000);
        _availabilitySaved = false;
    }

    private static string DayName(int day) => day switch
    {
        1 => "Lunes",
        2 => "Martes",
        3 => "Miércoles",
        4 => "Jueves",
        5 => "Viernes",
        6 => "Sábado",
        7 => "Domingo",
        _ => day.ToString()
    };
}
