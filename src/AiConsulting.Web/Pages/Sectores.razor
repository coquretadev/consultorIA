@page "/sectores"
@inject IPublicApiService ApiService

<PageTitle>Sectores Objetivo – AI Consulting</PageTitle>

<h1 class="mb-4">Sectores Objetivo</h1>
<p class="lead text-muted mb-5">Especializados en integrar IA en los sectores donde más impacto genera.</p>

@if (_sectors == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (_sectors.Count == 0)
{
    <p class="text-muted">No hay sectores disponibles en este momento.</p>
}
else
{
    <div class="row g-4">
        @foreach (var (sector, i) in _sectors.Select((s, i) => (s, i)))
        {
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body d-flex flex-column">
                        <div class="fs-1 mb-3">@GetSectorIcon(i)</div>
                        <h5 class="card-title fw-bold">@sector.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">@sector.Description</p>
                        @if (!string.IsNullOrWhiteSpace(sector.Benefits))
                        {
                            <div class="mt-3 p-2 bg-light rounded">
                                <small class="fw-semibold text-success">Beneficios IA:</small>
                                <p class="small mb-0 mt-1">@sector.Benefits</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="text-center mt-5">
    <p class="text-muted">¿Tu sector no aparece? Contáctanos igualmente.</p>
    <a href="/contacto" class="btn btn-primary">Hablar con un experto</a>
</div>

@code {
    private List<SectorModel>? _sectors;

    protected override async Task OnInitializedAsync()
    {
        _sectors = await ApiService.GetSectorsAsync();
    }

    private static string GetSectorIcon(int index) => index switch
    {
        0 => "🏢",
        1 => "💻",
        2 => "⚖️",
        _ => "📣"
    };
}
