@page "/servicios"
@inject IPublicApiService ApiService

<PageTitle>Nuestros Servicios – AI Consulting</PageTitle>

<h1 class="mb-4">Nuestros Servicios</h1>

@if (_services == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando servicios...</span>
        </div>
        <p class="mt-2 text-muted">Cargando servicios...</p>
    </div>
}
else if (_services.Count == 0)
{
    <p class="text-muted">No hay servicios disponibles en este momento.</p>
}
else
{
    <div class="row g-4">
        @foreach (var s in _services)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@s.Name</h5>
                        <p class="card-text text-muted flex-grow-1">@s.Description</p>
                        @if (!string.IsNullOrWhiteSpace(s.Benefits))
                        {
                            <div class="mb-3">
                                <small class="text-muted fw-semibold">Beneficios:</small>
                                <p class="small mb-0">@s.Benefits</p>
                            </div>
                        }
                        <div class="mt-auto">
                            <p class="mb-1 fw-semibold text-primary">€@s.PriceRangeMin.ToString("N0") – €@s.PriceRangeMax.ToString("N0")</p>
                            <p class="small text-muted mb-0">Tiempo estimado: @s.EstimatedDeliveryDays días</p>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/contacto" class="btn btn-sm btn-outline-primary w-100">Solicitar información</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ServiceSummaryModel>? _services;

    protected override async Task OnInitializedAsync()
    {
        _services = await ApiService.GetServicesAsync();
    }
}
